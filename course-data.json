        {
            "id": 2,
            "title": {
                "en": "People & Pronouns",
                "ar": "الأشخاص والضمائر"
            },
            "description": {
                "en": "Learn basic English pronouns.",
                "ar": "تعلم الضمائر الأساسية في اللغة الإنجليزية."
            },
            "terms": [
                {
                    "id": 105,
                    "term": {
                        "en": "I",
                        "ar": "أنا"
                    },
                    "meaning": {
                        "en": "Used to talk about yourself.",
                        "ar": "تُستخدم للتحدث عن نفسك."
                    },
                    "example": {
                        "en": "I am Ahmed.",
                        "ar": "أنا أحمد."
                    }
                },
                {
                    "id": 106,
                    "term": {
                        "en": "You",
                        "ar": "أنت"
                    },
                    "meaning": {
                        "en": "Used to talk to someone.",
                        "ar": "تُستخدم لمخاطبة شخص."
                    },
                    "example": {
                        "en": "You are my friend.",
                        "ar": "أنت صديقي."
                    }
                },
                {
                    "id": 107,
                    "term": {
                        "en": "He",
                        "ar": "هو"
                    },
                    "meaning": {
                        "en": "Used for a male.",
                        "ar": "تُستخدم للمذكر."
                    },
                    "example": {
                        "en": "He is a student.",
                        "ar": "هو طالب."
                    }
                },
                {
                    "id": 108,
                    "term": {
                        "en": "She",
                        "ar": "هي"
                    },
                    "meaning": {
                        "en": "Used for a female.",
                        "ar": "تُستخدم للمؤنث."
                    },
                    "example": {
                        "en": "She is a teacher.",
                        "ar": "هي معلمة."
                    }
                }
            ],
            "concept": {
                "id": 202,
                "title": {
                    "en": "Verb to be (am / is)",
                    "ar": "الفعل to be (am / is)"
                },
                "explanation": {
                    "en": "<p>I use <b>am</b>. He and She use <b>is</b>.</p>",
                    "ar": "<p>نستخدم <b>am</b> مع I و <b>is</b> مع He و She.</p>"
                },
                "type": "grammar"
            },
            "slides": [
                {
                    "id": 20,
                    "type": "concept",
                    "title": {
                        "en": "Verb to be",
                        "ar": "الفعل to be"
                    },
                    "content": {
                        "en": "<p>I am Ahmed. She is a teacher.</p>",
                        "ar": "<p>I am Ahmed. She is a teacher.</p>"
                    },
                    "sortOrder": 1
                }
            ]
        },
        {
