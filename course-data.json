        {
            "id": 1,
            "title": {
                "en": "Greetings",
                "ar": "التحيات"
            },
            "description": {
                "en": "Learn common English greetings.",
                "ar": "تعلم التحيات الشائعة في اللغة الإنجليزية."
            },
            "terms": [
                {
                    "id": 101,
                    "term": {
                        "en": "Hello",
                        "ar": "مرحباً"
                    },
                    "meaning": {
                        "en": "A greeting used when meeting someone.",
                        "ar": "تحية تُستخدم عند مقابلة شخص."
                    },
                    "example": {
                        "en": "Hello, Ahmed!",
                        "ar": "مرحباً يا أحمد!"
                    }
                },
                {
                    "id": 102,
                    "term": {
                        "en": "Hi",
                        "ar": "أهلاً"
                    },
                    "meaning": {
                        "en": "An informal greeting.",
                        "ar": "تحية غير رسمية."
                    },
                    "example": {
                        "en": "Hi, Sara!",
                        "ar": "أهلاً يا سارة!"
                    }
                },
                {
                    "id": 103,
                    "term": {
                        "en": "Good morning",
                        "ar": "صباح الخير"
                    },
                    "meaning": {
                        "en": "A greeting used in the morning.",
                        "ar": "تحية تُستخدم في الصباح."
                    },
                    "example": {
                        "en": "Good morning, teacher.",
                        "ar": "صباح الخير يا أستاذ."
                    }
                },
                {
                    "id": 104,
                    "term": {
                        "en": "Goodbye",
                        "ar": "مع السلامة"
                    },
                    "meaning": {
                        "en": "A word used when leaving.",
                        "ar": "كلمة تُستخدم عند المغادرة."
                    },
                    "example": {
                        "en": "Goodbye, see you later.",
                        "ar": "مع السلامة، أراك لاحقاً."
                    }
                }
            ],
            "concept": {
                "id": 201,
                "title": {
                    "en": "Using greetings",
                    "ar": "استخدام التحيات"
                },
                "explanation": {
                    "en": "<p>We use greetings when we meet or leave people.</p>",
                    "ar": "<p>نستخدم التحيات عند مقابلة الناس أو مغادرتهم.</p>"
                },
