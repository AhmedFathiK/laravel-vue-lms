                        "en": "Book",
                        "ar": "كتاب"
                    },
                    "meaning": {
                        "en": "Something you read.",
                        "ar": "شيء نقرأه."
                    },
                    "example": {
                        "en": "This is a book.",
                        "ar": "هذا كتاب."
                    }
                },
                {
                    "id": 110,
                    "term": {
                        "en": "Pen",
                        "ar": "قلم"
                    },
                    "meaning": {
                        "en": "Used for writing.",
                        "ar": "يُستخدم للكتابة."
                    },
                    "example": {
                        "en": "I have a pen.",
                        "ar": "لدي قلم."
                    }
                },
                {
                    "id": 111,
                    "term": {
                        "en": "Chair",
                        "ar": "كرسي"
                    },
                    "meaning": {
                        "en": "You sit on it.",
                        "ar": "نجلس عليه."
                    },
                    "example": {
                        "en": "The chair is red.",
                        "ar": "الكرسي أحمر."
                    }
                },
                {
                    "id": 112,
                    "term": {
                        "en": "Bag",
                        "ar": "حقيبة"
                    },
                    "meaning": {
                        "en": "You carry things in it.",
                        "ar": "نحمل فيها الأشياء."
                    },
                    "example": {
                        "en": "My bag is new.",
                        "ar": "حقيبتي جديدة."
                    }
                }
            ],
            "concept": {
                "id": 203,
                "title": {
                    "en": "This is / That is",
                    "ar": "This is / That is"
                },
                "explanation": {
                    "en": "<p>Use <b>This</b> for near objects and <b>That</b> for far objects.</p>",
                    "ar": "<p>نستخدم <b>This</b> للأشياء القريبة و <b>That</b> للأشياء البعيدة.</p>"
                },
                "type": "grammar"
            },
